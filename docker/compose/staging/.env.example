# Compose-only (not read by the app)
POSTGRES_PUBLISH_PORT=5434

NODE_ENV=development
PORT=5002
LOG_LEVEL=info

DB_HOST=accordo-postgres-staging
DB_PORT=5432
DB_NAME=accordo_mvp
DB_NAME_TEST=accordo_test
DB_USERNAME=accordo
DB_PASSWORD=change-me
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_ADMIN_DATABASE=accordo_mvp

JWT_SECRET=change-me-min-32-chars
JWT_ACCESS_TOKEN_SECRET=change-me-min-32-chars
JWT_REFRESH_TOKEN_SECRET=change-me-min-32-chars
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=10000

EMAIL_PROVIDER=nodemailer
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=465
SMTP_USER=your-ses-smtp-username
SMTP_PASS=your-ses-smtp-password
SMTP_FROM_EMAIL=your-verified-email@example.com

REDIS_URL=redis://host.docker.internal:6379

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=qwen3
LLM_TIMEOUT=60000

EMBEDDING_SERVICE_URL=http://host.docker.internal:5003

VENDOR_PORTAL_URL=http://your-server:5002/vendor
CHATBOT_FRONTEND_URL=http://your-server:3000
CHATBOT_API_URL=http://your-server:5002/api

LLM_PROVIDER=ollama
LLM_OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_OLLAMA_MODEL=llama3.1:8b
EMBEDDING_PROVIDER=ollama

LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=accordo-ai-negotiation

DATABASE_URL=postgres://accordo:change-me@accordo-postgres-staging:5432/accordo_mvp
